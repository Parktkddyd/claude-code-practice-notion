#!/usr/bin/env bash

# git-commit: 기능 단위별로 변경사항을 쪼개서 커밋하는 커맨드
# 사용법: git-commit [--help]

set -e

# 색상 정의
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# 함수: 도움말 표시
show_help() {
  cat << 'EOF'
사용법: git-commit [옵션]

기능 단위별로 변경사항을 쪼개서 단계별 커밋을 진행합니다.

옵션:
  --help, -h     이 도움말을 표시합니다
  --staged       이미 스테이징된 파일만 커밋합니다
  --all          모든 변경사항을 한 번에 커밋합니다

프로세스:
  1. 변경사항을 기능 단위별로 분류
  2. 각 기능별로 파일 선택하여 스테이징
  3. 커밋메세지 입력 (한글)
  4. 반복 또는 종료

예시:
  git-commit                 # 대화형 모드로 진행
  git-commit --staged        # 스테이징된 파일만 커밋
  git-commit --all           # 모든 변경사항 한 번에 커밋
EOF
}

# 함수: 변경사항 표시
show_changes() {
  echo -e "${CYAN}=== 현재 변경사항 ===${NC}"
  git status --short
}

# 함수: 파일 선택 (대화형)
select_files() {
  local files=()
  local file_list=$(git status --short | cut -c4-)
  local count=0

  echo -e "${CYAN}=== 변경된 파일 목록 ===${NC}"
  while IFS= read -r file; do
    if [ -n "$file" ]; then
      count=$((count + 1))
      echo "$count) $file"
      files+=("$file")
    fi
  done <<< "$file_list"

  if [ ${#files[@]} -eq 0 ]; then
    echo -e "${RED}변경사항이 없습니다.${NC}"
    return 1
  fi

  echo ""
  echo -e "${YELLOW}스테이징할 파일을 선택하세요 (쉼표로 구분, 예: 1,2,3 또는 all):${NC}"
  read -p "> " selection

  if [ "$selection" = "all" ]; then
    git add .
  else
    IFS=',' read -ra selected <<< "$selection"
    for idx in "${selected[@]}"; do
      idx=$((idx - 1))
      if [ $idx -ge 0 ] && [ $idx -lt ${#files[@]} ]; then
        git add "${files[$idx]}"
      fi
    done
  fi
}

# 함수: 커밋메세지 입력
get_commit_message() {
  echo ""
  echo -e "${YELLOW}커밋메세지를 입력하세요 (한글):${NC}"
  echo -e "${BLUE}형식: <타입>: <설명>${NC}"
  echo -e "${BLUE}  feat: 새 기능 추가${NC}"
  echo -e "${BLUE}  fix: 버그 수정${NC}"
  echo -e "${BLUE}  refactor: 코드 리팩토링${NC}"
  echo -e "${BLUE}  style: 코드 스타일 변경${NC}"
  echo -e "${BLUE}  docs: 문서 수정${NC}"
  echo -e "${BLUE}  test: 테스트 추가/수정${NC}"
  echo ""

  read -p "메세지: " commit_msg

  if [ -z "$commit_msg" ]; then
    echo -e "${RED}커밋메세지는 필수입니다.${NC}"
    return 1
  fi

  echo "$commit_msg"
}

# 함수: 커밋 실행
do_commit() {
  local msg="$1"

  git commit -m "$msg"

  if [ $? -eq 0 ]; then
    echo -e "${GREEN}✓ 커밋 완료: $msg${NC}"
    return 0
  else
    echo -e "${RED}✗ 커밋 실패${NC}"
    return 1
  fi
}

# 함수: 계속 진행 여부 확인
continue_commit() {
  echo ""
  read -p "다음 기능을 커밋하시겠습니까? (y/n): " response

  if [[ "$response" =~ ^[Yy]$ ]]; then
    return 0
  else
    return 1
  fi
}

# 함수: 남은 변경사항 확인
check_remaining_changes() {
  local remaining=$(git status --short | wc -l)

  if [ "$remaining" -gt 0 ]; then
    echo -e "${YELLOW}아직 스테이징되지 않은 변경사항이 있습니다.${NC}"
    show_changes
    return 0
  else
    echo -e "${GREEN}모든 변경사항이 커밋되었습니다.${NC}"
    return 1
  fi
}

# 메인 로직
main() {
  # 옵션 파싱
  case "${1:-}" in
    --help|-h)
      show_help
      exit 0
      ;;
    --all)
      # 모든 변경사항 한 번에 커밋
      echo -e "${CYAN}=== 모든 변경사항 커밋 ===${NC}"
      show_changes

      msg=$(get_commit_message) || exit 1
      git add .
      do_commit "$msg"
      exit 0
      ;;
    --staged)
      # 스테이징된 파일만 커밋
      echo -e "${CYAN}=== 스테이징된 파일 커밋 ===${NC}"
      git diff --cached --name-only

      msg=$(get_commit_message) || exit 1
      do_commit "$msg"
      exit 0
      ;;
  esac

  # 대화형 모드
  echo -e "${GREEN}=== 기능 단위별 커밋 도우미 ===${NC}"
  echo ""

  while true; do
    # 변경사항 확인
    if ! check_remaining_changes; then
      break
    fi

    echo ""

    # 파일 선택
    if select_files; then
      # 커밋메세지 입력
      msg=$(get_commit_message) || continue

      # 커밋 실행
      if do_commit "$msg"; then
        # 계속 진행 확인
        if ! continue_commit; then
          break
        fi
      fi
    else
      break
    fi
  done

  echo ""
  echo -e "${GREEN}커밋 완료!${NC}"
}

main "$@"
